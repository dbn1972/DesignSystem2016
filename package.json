{
  "name": "@figma/my-make-file",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest",
    "test:a11y": "vitest --run src/app/react-core-package/src/components/Field/Field.test.tsx src/app/react-core-package/src/components/Dialog/Dialog.test.tsx src/app/react-core-package/src/components/Table/Table.test.tsx src/app/react-core-package/src/components/Autocomplete/Autocomplete.test.tsx",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "check:docs-links": "node scripts/check-doc-links.mjs",
    "check:api-docs": "node scripts/check-api-doc-drift.mjs",
    "check:semantic-colors": "node scripts/check-semantic-colors.mjs",
    "check:semantic-colors:update": "node scripts/check-semantic-colors.mjs --update-baseline",
    "verify": "npm run typecheck && npm run build && npm run test:a11y && npm run check:docs-links && npm run check:api-docs && npm run check:semantic-colors",
    "test:visual": "playwright test",
    "test:cross-browser": "playwright test tests/visual/cross-browser.visual.ts",
    "test:lighthouse": "lhci autorun",
    "test:visual:update": "playwright test --update-snapshots",
    "test:visual:report": "playwright show-report",
    "publish:dry": "node scripts/publish.mjs",
    "publish:packages": "node scripts/publish.mjs --publish",
    "dev": "vite"
  },
