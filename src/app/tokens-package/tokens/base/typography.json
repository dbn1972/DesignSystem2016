{
  "$schema": "https://tr.designtokens.org/format/",
  "ux4g": {
    "typography": {
      "fontFamily": {
        "$type": "fontFamily",
        "sans": {
          "value": "system-ui, -apple-system, 'Segoe UI', 'Noto Sans', sans-serif",
          "description": "Primary sans-serif stack - optimized for Indian language support"
        },
        "serif": {
          "value": "Georgia, 'Times New Roman', serif",
          "description": "Serif font stack for traditional contexts"
        },
        "mono": {
          "value": "'Consolas', 'Monaco', 'Courier New', monospace",
          "description": "Monospace stack for code and data"
        },
        "devanagari": {
          "value": "'Noto Sans Devanagari', system-ui, sans-serif",
          "description": "Hindi (हिन्दी), Marathi (मराठी), Nepali - Devanagari script"
        },
        "tamil": {
          "value": "'Noto Sans Tamil', system-ui, sans-serif",
          "description": "Tamil (தமிழ்) - Tamil script"
        },
        "bengali": {
          "value": "'Noto Sans Bengali', system-ui, sans-serif",
          "description": "Bengali (বাংলা), Assamese (অসমীয়া) - Bengali-Assamese script"
        },
        "telugu": {
          "value": "'Noto Sans Telugu', system-ui, sans-serif",
          "description": "Telugu (తెలుగు) - Telugu script"
        },
        "gujarati": {
          "value": "'Noto Sans Gujarati', system-ui, sans-serif",
          "description": "Gujarati (ગુજરાતી) - Gujarati script"
        },
        "kannada": {
          "value": "'Noto Sans Kannada', system-ui, sans-serif",
          "description": "Kannada (ಕನ್ನಡ) - Kannada script"
        },
        "malayalam": {
          "value": "'Noto Sans Malayalam', system-ui, sans-serif",
          "description": "Malayalam (മലയാളം) - Malayalam script"
        },
        "punjabi": {
          "value": "'Noto Sans Gurmukhi', system-ui, sans-serif",
          "description": "Punjabi (ਪੰਜਾਬੀ) - Gurmukhi script"
        },
        "odia": {
          "value": "'Noto Sans Oriya', system-ui, sans-serif",
          "description": "Odia (ଓଡ଼ିଆ) - Odia script"
        },
        "urdu": {
          "value": "'Noto Nastaliq Urdu', 'Noto Sans Arabic', serif",
          "description": "Urdu (اردو) - Nastaliq (Perso-Arabic) script, RTL"
        },
        "kashmiri": {
          "value": "'Noto Sans Arabic', 'Noto Nastaliq Urdu', serif",
          "description": "Kashmiri (कॉशुर/کٲشُر) - Perso-Arabic and Devanagari scripts"
        },
        "sindhi": {
          "value": "'Noto Sans Arabic', 'Noto Sans Devanagari', serif",
          "description": "Sindhi (सिन्धी/سنڌي) - Perso-Arabic and Devanagari scripts"
        }
      },
      "fontSize": {
        "$type": "dimension",
        "xs": { "value": "0.75rem", "description": "12px - Caption, metadata" },
        "sm": { "value": "0.875rem", "description": "14px - Small body text, labels" },
        "base": { "value": "1rem", "description": "16px - Base body text (WCAG minimum)" },
        "lg": { "value": "1.125rem", "description": "18px - Large body, subtitle" },
        "xl": { "value": "1.25rem", "description": "20px - Small heading" },
        "2xl": { "value": "1.5rem", "description": "24px - H3 heading" },
        "3xl": { "value": "1.875rem", "description": "30px - H2 heading" },
        "4xl": { "value": "2.25rem", "description": "36px - H1 heading" },
        "5xl": { "value": "3rem", "description": "48px - Display heading" },
        "6xl": { "value": "3.75rem", "description": "60px - Hero heading" },
        "7xl": { "value": "4.5rem", "description": "72px - Extra large display" }
      },
      "fontWeight": {
        "$type": "fontWeight",
        "light": { "value": "300", "description": "Light weight - use sparingly" },
        "normal": { "value": "400", "description": "Normal body weight" },
        "medium": { "value": "500", "description": "Medium emphasis" },
        "semibold": { "value": "600", "description": "Semibold - headings, emphasis" },
        "bold": { "value": "700", "description": "Bold - strong emphasis" },
        "extrabold": { "value": "800", "description": "Extra bold - display text" }
      },
      "lineHeight": {
        "$type": "number",
        "tight": { "value": "1.25", "description": "Tight leading for headings" },
        "snug": { "value": "1.375", "description": "Snug leading" },
        "normal": { "value": "1.5", "description": "Normal leading - WCAG recommended" },
        "relaxed": { "value": "1.625", "description": "Relaxed leading for readability" },
        "loose": { "value": "2", "description": "Loose leading for accessibility" }
      },
      "letterSpacing": {
        "$type": "dimension",
        "tighter": { "value": "-0.05em", "description": "Tighter tracking" },
        "tight": { "value": "-0.025em", "description": "Tight tracking" },
        "normal": { "value": "0em", "description": "Normal tracking" },
        "wide": { "value": "0.025em", "description": "Wide tracking" },
        "wider": { "value": "0.05em", "description": "Wider tracking" },
        "widest": { "value": "0.1em", "description": "Widest tracking - all caps" }
      },
      "textCase": {
        "$type": "string",
        "none": { "value": "none", "description": "No transformation" },
        "uppercase": { "value": "uppercase", "description": "ALL CAPS - use with wider tracking" },
        "lowercase": { "value": "lowercase", "description": "lowercase" },
        "capitalize": { "value": "capitalize", "description": "Capitalize First Letter" }
      }
    }
  }
}
