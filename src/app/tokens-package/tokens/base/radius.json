{
  "$schema": "https://tr.designtokens.org/format/",
  "ux4g": {
    "radius": {
      "$type": "dimension",
      "none": { "value": "0px", "description": "No radius - sharp corners" },
      "sm": { "value": "0.125rem", "description": "2px - Subtle radius" },
      "base": { "value": "0.25rem", "description": "4px - Base radius" },
      "md": { "value": "0.375rem", "description": "6px - Medium radius" },
      "lg": { "value": "0.5rem", "description": "8px - Large radius" },
      "xl": { "value": "0.75rem", "description": "12px - XL radius" },
      "2xl": { "value": "1rem", "description": "16px - 2XL radius" },
      "3xl": { "value": "1.5rem", "description": "24px - 3XL radius" },
      "full": { "value": "9999px", "description": "Full radius - pills and circles" },
      "description": "Border radius scale - government-grade restraint"
    }
  }
}
