{
  "$schema": "https://tr.designtokens.org/format/",
  "ux4g": {
    "component": {
      "checkbox": {
        "base": {
          "$type": "dimension",
          "size": {
            "sm": { "value": "16px", "description": "Small checkbox size" },
            "md": { "value": "20px", "description": "Medium checkbox size - default" },
            "lg": { "value": "24px", "description": "Large checkbox size - WCAG touch target" }
          },
          "borderWidth": {
            "default": { "value": "2px", "description": "Default border width - WCAG non-text contrast" },
            "checked": { "value": "2px", "description": "Checked state border width" }
          },
          "borderRadius": {
            "value": "4px",
            "description": "Checkbox border radius - government-grade restraint"
          },
          "iconSize": {
            "sm": { "value": "10px", "description": "Small check icon size" },
            "md": { "value": "12px", "description": "Medium check icon size" },
            "lg": { "value": "14px", "description": "Large check icon size" }
          },
          "transition": {
            "duration": { "value": "150ms", "description": "Checkbox transition duration" },
            "timing": { "value": "ease-in-out", "description": "Checkbox transition timing function" }
          }
        },
        "state": {
          "unchecked": {
            "$type": "color",
            "background": { "value": "#ffffff", "description": "Unchecked background - White" },
            "border": { "value": "#525252", "description": "Unchecked border - Neutral 600 (WCAG AA)" }
          },
          "checked": {
            "$type": "color",
            "background": { "value": "#005196", "description": "Checked background - Navy 500" },
            "border": { "value": "#005196", "description": "Checked border - Navy 500" },
            "icon": { "value": "#ffffff", "description": "Check icon color - White" }
          },
          "indeterminate": {
            "$type": "color",
            "background": { "value": "#005196", "description": "Indeterminate background - Navy 500" },
            "border": { "value": "#005196", "description": "Indeterminate border - Navy 500" },
            "icon": { "value": "#ffffff", "description": "Minus icon color - White" }
          },
          "hover": {
            "$type": "color",
            "unchecked": {
              "background": { "value": "#fafafa", "description": "Unchecked hover background - Neutral 50" },
              "border": { "value": "#404040", "description": "Unchecked hover border - Neutral 700" }
            },
            "checked": {
              "background": { "value": "#004178", "description": "Checked hover background - Navy 600" },
              "border": { "value": "#004178", "description": "Checked hover border - Navy 600" }
            }
          },
          "focus": {
            "$type": "color",
            "ring": { "value": "#005196", "description": "Focus ring color - Navy 500" },
            "ringOpacity": { "value": "0.3", "description": "Focus ring opacity" }
          },
          "disabled": {
            "$type": "color",
            "unchecked": {
              "background": { "value": "#fafafa", "description": "Disabled unchecked background - Neutral 50" },
              "border": { "value": "#d4d4d4", "description": "Disabled border - Neutral 300" }
            },
            "checked": {
              "background": { "value": "#d4d4d4", "description": "Disabled checked background - Neutral 300" },
              "border": { "value": "#d4d4d4", "description": "Disabled checked border - Neutral 300" },
              "icon": { "value": "#a3a3a3", "description": "Disabled icon - Neutral 400" }
            },
            "cursor": { "value": "not-allowed", "description": "Disabled cursor style" }
          },
          "error": {
            "$type": "color",
            "border": { "value": "#dc2626", "description": "Error border - Error DEFAULT" },
            "ring": { "value": "#dc2626", "description": "Error focus ring - Error DEFAULT" }
          }
        },
        "label": {
          "$type": "dimension",
          "gap": {
            "sm": { "value": "8px", "description": "Gap between checkbox and label - small" },
            "md": { "value": "12px", "description": "Gap between checkbox and label - medium" },
            "lg": { "value": "16px", "description": "Gap between checkbox and label - large" }
          },
          "$type": "color",
          "text": {
            "default": { "value": "#171717", "description": "Label text - Neutral 900" },
            "disabled": { "value": "#a3a3a3", "description": "Disabled label text - Neutral 400" }
          }
        },
        "accessibility": {
          "$type": "dimension",
          "minTouchTarget": {
            "value": "44px",
            "description": "Minimum touch target size per WCAG 2.5.5"
          },
          "focusRingWidth": {
            "value": "2px",
            "description": "Focus ring width for accessibility"
          },
          "focusRingOffset": {
            "value": "2px",
            "description": "Focus ring offset from checkbox edge"
          }
        }
      }
    }
  }
}
