{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "types": ["@storybook/react", "node"],
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
